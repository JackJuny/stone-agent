# Stone Agent 配置文件
# 路径: /etc/stone/config.yaml

# ============================================================
# Profile 配置
# 预留插件系统，未来支持不同配置模板
# 可选值: default, singbox, docker
# ============================================================
profile: default

# ============================================================
# 服务器信息
# 用于标识和区分多台VPS
# ============================================================
server:
  # 服务器ID（英文简写，如 sg01, jp01, hk01）
  id: sg01
  # 服务器唯一ID（自动生成，首次启动后不要修改）
  server_id: "auto"
  # 服务器名称（中文，用于Telegram消息显示）
  name: 新加坡VPS
  # 服务器位置
  location: Singapore
  # 服务器角色（可选）
  role: sing-box

# ============================================================
# Telegram Bot 配置
# 从 @BotFather 获取 Bot Token
# ============================================================
telegram:
  # Bot Token（必填）
  # 格式: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
  bot_token: "YOUR_BOT_TOKEN"

  # Chat ID（必填）
  # 你的 Telegram 用户ID，可通过 @userinfobot 获取
  chat_id: "YOUR_CHAT_ID"

  # 允许执行控制命令的用户ID列表
  # 只有列表中的用户可以执行重启、服务控制等操作
  # 普通用户只允许查看状态
  allowed_users:
    - 123456789
    # - 987654321  # 可添加多个用户

# ============================================================
# 日报配置
# ============================================================
report:
  # 时区（必填）
  # 常用: Asia/Singapore, Asia/Tokyo, Asia/Hong_Kong, Asia/Shanghai
  timezone: Asia/Singapore

  # 每日报告发送时间（24小时制 HH:MM）
  daily_time: "22:00"

# ============================================================
# 监控配置
# 超过阈值会发送告警
# ============================================================
monitor:
  # CPU使用率告警阈值（百分比）
  cpu_threshold: 90

  # 内存使用率告警阈值（百分比）
  memory_threshold: 90

  # 磁盘使用率告警阈值（百分比）
  disk_threshold: 85

  # 网络监控接口名称
  # 常见: eth0, ens3, enp0s3
  # 查看方法: ip link show
  network_interface: eth0

# ============================================================
# 数据库配置
# SQLite 数据库路径: /var/lib/stone/stone.db
# ============================================================
database:
  # 数据保留天数（自动清理过期数据）
  retention_days: 90

# ============================================================
# 操作配置（Action框架）
# 控制远程操作的安全性和行为
# ============================================================
actions:
  # 是否启用远程操作
  enabled: true

  # 高危操作确认超时时间（秒）
  # 超时后确认失效，需要重新发起
  confirm_timeout: 60

  # 系统级操作权限
  allow:
    # 允许重启服务器
    reboot: true
    # 允许关闭服务器（危险，建议禁用）
    shutdown: false
    # 允许重启 Stone Agent
    restart_agent: true

  # 服务级操作权限
  # 每个服务可以独立配置允许的操作
  services:
    sing-box:
      # 允许的操作列表: status, start, stop, restart
      allow:
        - status
        - start
        - stop
        - restart
    docker:
      allow:
        - status
        - restart
    caddy:
      allow:
        - status

  # 操作冷却时间（秒）
  # 防止短时间内重复执行相同操作
  cooldown:
    # 重启Agent的冷却时间
    restart_agent: 30
    # 重启服务器的冷却时间（建议较长）
    reboot: 300
    # 重启服务的冷却时间
    service_restart: 30
    # 启动服务的冷却时间
    service_start: 10
    # 停止服务的冷却时间
    service_stop: 10

# ============================================================
# 告警引擎配置
# 状态变化检测，避免重复告警
# ============================================================
alerts:
  # 是否启用告警引擎
  enabled: true
  # 是否发送恢复通知
  notify_recovery: true
  # 告警冷却时间（分钟）
  # 相同告警在此时间内不重复发送
  cooldown: 30

# ============================================================
# 安全模块配置
# 检测 UFW、Fail2ban 状态
# ============================================================
security:
  # 是否启用安全模块
  enabled: true
  # UFW 检测
  ufw:
    enabled: true
  # Fail2ban 检测
  fail2ban:
    enabled: true
  # 通知配置
  notifications:
    # 安全事件通知（SSH封禁等）
    security: true

# ============================================================
# 服务监控列表
# 监控 systemd 服务状态
# ============================================================
services:
  - sing-box
  - nginx
  - docker
  # - caddy
  # - mysql
  # - redis

# ============================================================
# 端口检测（sing-box插件）
# 检测指定端口是否可访问
# ============================================================
ports:
  - 443
  - 52536

# ============================================================
# Docker容器检测（docker插件）
# 检测指定容器是否运行
# ============================================================
containers:
  - nginx
  - mysql
  - redis
  # - mongodb
  # - postgres
